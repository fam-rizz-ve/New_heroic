# New Heroic Backend Configuration
# Copy this file to backend/.env and adjust as needed
#
# IPC Architecture:
#   Frontend (Tauri webview, port 1420) ──HTTP──► Backend (FastAPI sidecar, port 1430)
#   In dev:  Vite dev server at http://localhost:1420
#   In prod: Tauri webview at tauri://localhost
#   CORS origins must include both for the health check to work in all environments

# Server
HOST=127.0.0.1
BACKEND_PORT=1430
DEBUG=false
LOG_LEVEL=info

# CORS origins (comma-separated in .env, parsed as list by pydantic-settings)
CORS_ORIGINS=["http://localhost:1420", "tauri://localhost"]

# Frontend port (for documentation/reference only)
FRONTEND_PORT=1420
